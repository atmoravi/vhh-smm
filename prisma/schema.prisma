generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  MANAGER
  WORKER
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
}

enum PaidPlatform {
  META_ADS
  TIKTOK_ADS
}

enum PostStatus {
  IDEA
  IN_PROGRESS
  PUBLISHED
}

enum TimeActivityType {
  CONTENT_PLANNING
  CONTENT_CREATION
  EDITING
  COMMUNITY_MANAGEMENT
  REPORTING
  MEETING
  OTHER
}

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  role            UserRole      @default(WORKER)
  passwordHash    String
  isActive        Boolean       @default(true)
  profileImageUrl String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?
  createdBy       User?         @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers    User[]        @relation("UserCreatedBy")
  authSessions    AuthSession[]
  timeEntries     TimeEntry[]
  organicPosts    OrganicPost[] @relation("PostOwner")

  @@index([role, isActive])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model WorkWeek {
  id            String             @id @default(cuid())
  label         String             @unique
  weekStartDate DateTime
  weekEndDate   DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  timeEntries   TimeEntry[]
  organicPosts  OrganicPost[]
  paidMetrics   PaidWeeklyMetric[]
  kpiSnapshots  KpiWeeklySnapshot[]

  @@index([weekStartDate])
}

model TimeEntry {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekId        String
  week          WorkWeek         @relation(fields: [weekId], references: [id], onDelete: Cascade)
  activityType  TimeActivityType
  workDate      DateTime
  minutesSpent  Int
  notes         String?
  linkedPostId  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, workDate])
  @@index([weekId, activityType])
}

model OrganicPost {
  id               String      @id @default(cuid())
  weekId           String
  week             WorkWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  ownerUserId      String?
  ownerUser        User?       @relation("PostOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  platform         Platform
  title            String?
  theme            String
  status           PostStatus  @default(IDEA)
  publishDate      DateTime?
  timeSpentMinutes Int         @default(0)
  views            Int         @default(0)
  likes            Int         @default(0)
  comments         Int         @default(0)
  shares           Int         @default(0)
  saves            Int         @default(0)
  profileVisits    Int         @default(0)
  followersDelta   Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([weekId, platform])
  @@index([ownerUserId, publishDate])
}

model PaidWeeklyMetric {
  id          String       @id @default(cuid())
  weekId      String
  week        WorkWeek     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  platform    PaidPlatform
  spendEur    Decimal      @db.Decimal(12, 2)
  impressions Int          @default(0)
  clicks      Int          @default(0)
  ctr         Decimal?     @db.Decimal(8, 4)
  cpc         Decimal?     @db.Decimal(12, 4)
  cpm         Decimal?     @db.Decimal(12, 4)
  conversions Int          @default(0)
  leads       Int          @default(0)
  revenueEur  Decimal?     @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([weekId, platform])
}

model KpiWeeklySnapshot {
  id                      String   @id @default(cuid())
  weekId                  String
  week                    WorkWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  laborCostEur            Decimal  @db.Decimal(12, 2)
  adSpendEur              Decimal  @db.Decimal(12, 2)
  organicQualifiedOutcome Decimal  @db.Decimal(14, 4)
  paidQualifiedOutcome    Decimal  @db.Decimal(14, 4)
  organicEfficiency       Decimal  @db.Decimal(14, 6)
  paidEfficiency          Decimal  @db.Decimal(14, 6)
  catchUpRatio            Decimal  @db.Decimal(14, 6)
  investmentJustified     Boolean
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([weekId])
}
